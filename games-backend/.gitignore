.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# IDE — IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# IDE — NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# IDE — VS Code
.vscode/

# Local config (DB credentials etc.)
**/src/main/resources/application-local.properties
**/src/main/resources/application-*.properties

# Environment
.env
.env.*
.env.local
!.env.example

# Logs
*.log

# Help
HELP.md

