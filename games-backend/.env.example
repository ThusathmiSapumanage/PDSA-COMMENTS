# Copy this file to .env for local backend development.
# JWT secret must be at least 32 bytes long.
jwt.secret=replace-with-a-strong-32-byte-secret-value
jwt.expiration-ms=86400000

# Local database credentials (required at startup).
DB_USERNAME=replace-with-your-db-username
DB_PASSWORD=replace-with-your-db-password

# Backend server port
SERVER_PORT=8080